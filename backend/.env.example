# ============================================================
# CancerGuard AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# --- Security ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-key-here

# --- Database ---
# For local development: leave blank (uses SQLite automatically)
# For production (Render): paste your Neon / Supabase PostgreSQL URL here
DATABASE_URL=

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Frontend URL (for CORS) ---
# Set this to your live Vercel frontend URL once deployed
# Example: https://cancerguard-ai.vercel.app
FRONTEND_URL=http://localhost:3000
